{
  "name": "nations-data-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + TypeScript end-to-end and smoke tests for NationsData (www.thenationsdata.com)",
  "type": "module",
  "scripts": {
    "test": "node scripts/test-and-report.mjs",
    "regression": "node scripts/test-and-report.mjs --grep @regression",
    "test:chromium": "node scripts/test-and-report.mjs --project=chromium",
    "test:firefox": "node scripts/test-and-report.mjs --project=firefox",
    "test:webkit": "node scripts/test-and-report.mjs --project=webkit",
    "test:mobile": "node scripts/test-and-report.mjs --project=mobile",
    "smoke": "node scripts/test-and-report.mjs --grep @smoke",
    "smoke:chromium": "node scripts/test-and-report.mjs --project=chromium --grep @smoke",
    "smoke:firefox": "node scripts/test-and-report.mjs --project=firefox --grep @smoke",
    "smoke:webkit": "node scripts/test-and-report.mjs --project=webkit --grep @smoke",
    "smoke:mobile": "node scripts/test-and-report.mjs --project=mobile --grep @smoke",
    "smoke:headed": "node scripts/test-and-report.mjs --project=chromium --grep @smoke --headed --workers=1",
    "test:headed": "node scripts/test-and-report.mjs --headed",
    "test:raw": "playwright test",
    "test:visual": "node scripts/test-and-report.mjs --project=chromium --grep @visual",
    "visual:update": "playwright test --project=chromium --grep @visual --update-snapshots",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "codegen": "playwright codegen https://www.thenationsdata.com"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "typescript": "^5.7.3"
  }
}
