{
  "name": "nations-data-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright + TypeScript end-to-end and smoke tests for NationsData (www.thenationsdata.com)",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "smoke": "playwright test --grep @smoke",
    "smoke:chromium": "playwright test --project=chromium --grep @smoke",
    "smoke:firefox": "playwright test --project=firefox --grep @smoke",
    "smoke:webkit": "playwright test --project=webkit --grep @smoke",
    "smoke:mobile": "playwright test --project=mobile --grep @smoke",
    "smoke:headed": "playwright test --project=chromium --grep @smoke --headed --workers=1",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://www.thenationsdata.com"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
